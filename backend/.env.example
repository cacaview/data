# ==============================================
# ACTAP Environment Configuration
# ==============================================
# This file documents all environment variables.
# Copy to `.env` and fill in real values for local development.

# ---- Application ----
APP_NAME=ACTAP
APP_VERSION=1.0.0
# ENVIRONMENT: development | staging | production
ENVIRONMENT=development
DEBUG=false

# ---- Server ----
HOST=0.0.0.0
PORT=8001
WORKERS=1

# ---- Database ----
# SQLite URL: file path is resolved relative to DATA_DIR
DATABASE_URL=sqlite:///./actap.db
# Directory for SQLite database + cache files (created if missing)
DATA_DIR=./data

# ---- Security ----
# Comma-separated allowed origins for CORS. Use specific origins in production.
# Use "*" only in development.
CORS_ORIGINS=*
# API key for protected endpoints (refresh, chat). Leave empty in dev to disable auth.
# In production, ALWAYS set a strong random value.
API_KEY=
# Comma-separated path prefixes that require X-API-Key
API_KEY_PROTECTED_PATHS=/api/datasources/refresh,/api/chat

# ---- Rate Limiting ----
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_STRICT_PER_MINUTE=10

# ---- AI Assistant (OpenAI-compatible API) ----
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.deepseek.com
MODEL_NAME=deepseek-chat

# ---- Logging ----
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# json | text
LOG_FORMAT=text
